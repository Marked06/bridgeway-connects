            { "value": "UT", "label": "Utah" },
            { "value": "VT", "label": "Vermont" },
            { "value": "VA", "label": "Virginia" },
            { "value": "WA", "label": "Washington" },
            { "value": "WV", "label": "West Virginia" },
            { "value": "WI", "label": "Wisconsin" },
            { "value": "WY", "label": "Wyoming" }
          ]
        },
        {
          "id": "language",
          "type": "select",
          "label": "Preferred language",
          "required": true,
          "default": "en",
          "options": [
            { "value": "en", "label": "English" },
            { "value": "es", "label": "Spanish" },
            { "value": "fr", "label": "French" },
            { "value": "pt", "label": "Portuguese" },
            { "value": "ar", "label": "Arabic" },
            { "value": "sw", "label": "Swahili" }
          ]
        }
      ]
    },
    {
      "id": "safety",
      "title": "Immediate safety",
      "questions": [
        {
          "id": "immediate_danger",
          "type": "select",
          "label": "Are you in immediate danger right now?",
          "required": true,
          "options": [
            { "value": "yes", "label": "Yes" },
            { "value": "no", "label": "No" },
            { "value": "prefer_not_to_answer", "label": "Prefer Not To Answer" }
          ],
          "scores": {
            "yes": { "safety_risk": 3 }
          },
          "tags": {
            "yes": ["crisis_support", "safety_planning"]
          }
        },
        {
          "id": "safe_place_tonight",
          "type": "select",
          "label": "Do you have a safe place to stay tonight?",
          "required": true,
          "options": [
            { "value": "yes", "label": "Yes" },
            { "value": "no", "label": "No" },
            { "value": "not_sure", "label": "Not Sure" },
            { "value": "prefer_not_to_answer", "label": "Prefer Not To Answer" }
          ],
          "scores": {
            "no": { "safety_risk": 2 }
          },
          "tags": {
            "no": ["housing_shelter", "crisis_support"]
          }
        },
        {
          "id": "monitored",
          "type": "select",
          "label": "Is someone monitoring your phone, messages, or movements?",
          "required": true,
          "options": [
            { "value": "yes", "label": "Yes" },
            { "value": "no", "label": "No" },
            { "value": "not_sure", "label": "Not Sure" },
            { "value": "prefer_not_to_answer", "label": "Prefer Not To Answer" }
          ],
          "scores": {
            "yes": { "safety_risk": 1, "coercion_score": 2 }
          },
          "tags": {
            "yes": ["safety_planning", "victim_support"]
          }
        }
      ]
    },
    {
      "id": "control_coercion",
      "title": "Control, pressure, or threats",
      "questions": [
        {
          "id": "forced_work_or_activity",
          "type": "select",
          "label": "Has anyone made you do work, services, or activities you did not want to do?",
          "required": true,
          "options": [
            { "value": "yes", "label": "Yes" },
            { "value": "no", "label": "No" },
            { "value": "not_sure", "label": "Not Sure" },
            { "value": "prefer_not_to_answer", "label": "Prefer Not To Answer" }
          ],
          "scores": {
            "yes": { "trafficking_score": 3 },
            "not_sure": { "trafficking_score": 1 }
          },
          "tags": {
            "yes": ["trafficking_support", "victim_support"]
          }
        },
        {
          "id": "threatened_you_or_family",
          "type": "select",
          "label": "Has anyone threatened you, your family, or someone you care about?",
          "required": true,
          "options": [
            { "value": "yes", "label": "Yes" },
            { "value": "no", "label": "No" },
            { "value": "not_sure", "label": "Not Sure" },
            { "value": "prefer_not_to_answer", "label": "Prefer Not To Answer" }
          ],
          "scores": {
            "yes": { "safety_risk": 1, "coercion_score": 2 }
          },
          "tags": {
            "yes": ["safety_planning", "victim_support"]
          }
        },
        {
          "id": "threatened_immigration_or_police",
          "type": "select",
          "label": "Has anyone threatened to report you to immigration, police, or other authorities?",
          "required": true,
          "options": [
            { "value": "yes", "label": "Yes" },
            { "value": "no", "label": "No" },
            { "value": "not_sure", "label": "Not Sure" },
            { "value": "prefer_not_to_answer", "label": "Prefer Not To Answer" }
          ],
          "scores": {
            "yes": { "coercion_score": 2, "immigration_need": 1 }
          },
          "tags": {
            "yes": ["immigration_legal_screening", "victim_support"]
          }
        },
        {
          "id": "controlled_documents",
          "type": "select",
          "label": "Has anyone taken or controlled your passport, ID, money, or important documents?",
          "required": true,
          "options": [
            { "value": "yes", "label": "Yes" },
            { "value": "no", "label": "No" },
            { "value": "not_sure", "label": "Not Sure" },
            { "value": "prefer_not_to_answer", "label": "Prefer Not To Answer" }
          ],
          "scores": {
            "yes": { "trafficking_score": 3, "immigration_need": 1 },
            "not_sure": { "trafficking_score": 1 }
          },
          "tags": {
            "yes": ["case_management", "legal_help", "trafficking_support"]
          }
        },
        {
          "id": "can_leave_freely",
          "type": "select",
          "label": "Are you able to leave your work, housing, or situation freely if you want to?",
          "required": true,
          "options": [
            { "value": "yes", "label": "Yes" },
            { "value": "no", "label": "No" },
            { "value": "not_sure", "label": "Not Sure" },
            { "value": "prefer_not_to_answer", "label": "Prefer Not To Answer" }
          ],
          "scores": {
            "no": { "trafficking_score": 3, "coercion_score": 2 },
            "not_sure": { "trafficking_score": 1 }
          },
          "tags": {
            "no": ["trafficking_support", "safety_planning", "victim_support"]
          }
        }
      ]
    },
    {
      "id": "work_exploitation",
      "title": "Work conditions",
      "questions": [
        {
          "id": "promised_job_different",
          "type": "select",
          "label": "Were you promised one kind of job but made to do different work?",
          "required": true,
          "options": [
            { "value": "yes", "label": "Yes" },
            { "value": "no", "label": "No" },
            { "value": "not_sure", "label": "Not Sure" },
            { "value": "prefer_not_to_answer", "label": "Prefer Not To Answer" }
          ],
          "scores": {
            "yes": { "labor_exploitation_score": 2 }
          },
          "tags": {
            "yes": ["employment_support", "legal_help"]
          }
        },
        {
          "id": "not_paid_or_underpaid",
          "type": "select",
          "label": "Have you been paid less than promised or not paid at all?",
          "required": true,
          "options": [
            { "value": "yes", "label": "Yes" },
            { "value": "no", "label": "No" },
            { "value": "not_sure", "label": "Not Sure" },
            { "value": "prefer_not_to_answer", "label": "Prefer Not To Answer" }
          ],
          "scores": {
            "yes": { "labor_exploitation_score": 2 }
          },
          "tags": {
            "yes": ["employment_support", "financial_assistance", "legal_help"]
          }
        },
        {
          "id": "unsafe_or_excessive_hours",
          "type": "select",
          "label": "Have you been forced to work long hours, without breaks, or in unsafe conditions?",
          "required": true,
          "options": [
            { "value": "yes", "label": "Yes" },
            { "value": "no", "label": "No" },
            { "value": "not_sure", "label": "Not Sure" },
            { "value": "prefer_not_to_answer", "label": "Prefer Not To Answer" }
          ],
          "scores": {
            "yes": { "labor_exploitation_score": 2, "trafficking_score": 1 }
          },
          "tags": {
            "yes": ["employment_support", "medical_care", "trafficking_support"]
          }
        },
        {
          "id": "debt_pressure",
          "type": "select",
          "label": "Has anyone told you that you owe a debt that you must work off?",
          "required": true,
          "options": [
            { "value": "yes", "label": "Yes" },
            { "value": "no", "label": "No" },
            { "value": "not_sure", "label": "Not Sure" },
            { "value": "prefer_not_to_answer", "label": "Prefer Not To Answer" }
          ],
          "scores": {
            "yes": { "trafficking_score": 3 }
          },
          "tags": {
            "yes": ["trafficking_support", "legal_help", "case_management"]
          }
        }
      ]
    },
    {
      "id": "sexual_exploitation",
      "title": "Sexual exploitation or assault",
      "questions": [
        {
          "id": "forced_sexual_activity",
          "type": "select",
          "label": "Has anyone pressured, forced, or manipulated you into sexual activity you did not want?",
          "required": true,
          "options": [
            { "value": "yes", "label": "Yes" },
            { "value": "no", "label": "No" },
            { "value": "not_sure", "label": "Not Sure" },
            { "value": "prefer_not_to_answer", "label": "Prefer Not To Answer" }
          ],
          "scores": {
            "yes": { "sexual_violence_score": 3 }
          },
          "tags": {
            "yes": ["sexual_assault_support", "crisis_support", "victim_support"]
          }
        },
        {
          "id": "sex_for_needs",
          "type": "select",
          "label": "Has anyone made you exchange sexual activity for money, housing, food, safety, or other basic needs?",
          "required": true,
          "options": [
            { "value": "yes", "label": "Yes" },
            { "value": "no", "label": "No" },
            { "value": "not_sure", "label": "Not Sure" },
            { "value": "prefer_not_to_answer", "label": "Prefer Not To Answer" }
          ],
          "scores": {
            "yes": { "sexual_violence_score": 3, "trafficking_score": 2 }
          },
          "tags": {
            "yes": ["sexual_assault_support", "trafficking_support", "victim_support"]
          }
        }
      ]
    },
    {
      "id": "relationship_abuse",
      "title": "Relationship or family abuse",
      "questions": [
        {
          "id": "partner_controls_life",
          "type": "select",
          "label": "Has a partner or family member controlled where you go, who you talk to, or what you do?",
          "required": true,
          "options": [
            { "value": "yes", "label": "Yes" },
            { "value": "no", "label": "No" },
            { "value": "not_sure", "label": "Not Sure" },
            { "value": "prefer_not_to_answer", "label": "Prefer Not To Answer" }
          ],
          "scores": {
            "yes": { "dv_score": 2 }
          },
          "tags": {
            "yes": ["domestic_violence_support", "safety_planning"]
