        },
        {
          "id": "partner_hurt_or_threatened",
          "type": "select",
          "label": "Has a partner or family member physically hurt, threatened, or intimidated you?",
          "required": true,
          "options": [
            { "value": "yes", "label": "Yes" },
            { "value": "no", "label": "No" },
            { "value": "not_sure", "label": "Not Sure" },
            { "value": "prefer_not_to_answer", "label": "Prefer Not To Answer" }
          ],
          "scores": {
            "yes": { "dv_score": 3, "safety_risk": 1 }
          },
          "tags": {
            "yes": ["domestic_violence_support", "crisis_support", "victim_support"]
          }
        }
      ]
    },
    {
      "id": "immigration",
      "title": "Immigration and legal support",
      "questions": [
        {
          "id": "wants_immigration_help",
          "type": "select",
          "label": "Would you like help understanding immigration options that may be available to some victims of crime, abuse, or exploitation?",
          "required": true,
          "options": [
            { "value": "yes", "label": "Yes" },
            { "value": "no", "label": "No" },
            { "value": "not_sure", "label": "Not Sure" },
            { "value": "prefer_not_to_answer", "label": "Prefer Not To Answer" }
          ],
          "scores": {
            "yes": { "immigration_need": 2 },
            "not_sure": { "immigration_need": 1 }
          },
          "tags": {
            "yes": ["immigration_legal_screening"],
            "not_sure": ["immigration_legal_screening"]
          }
        },
        {
          "id": "status_or_documents_concern",
          "type": "select",
          "label": "Do you have concerns about your immigration status, work authorization, or documents?",
          "required": true,
          "options": [
            { "value": "yes", "label": "Yes" },
            { "value": "no", "label": "No" },
            { "value": "not_sure", "label": "Not Sure" },
            { "value": "prefer_not_to_answer", "label": "Prefer Not To Answer" }
          ],
          "scores": {
            "yes": { "immigration_need": 2 }
          },
          "tags": {
            "yes": ["immigration_legal_screening", "case_management"]
          }
        }
      ]
    },
    {
      "id": "needs",
      "title": "What support do you need right now?",
      "questions": [
        {
          "id": "needs_now",
          "type": "multiselect",
          "label": "Select any support you need right now",
          "required": true,
          "options": [
            { "value": "shelter", "label": "Safe Housing / Shelter" },
            { "value": "food", "label": "Food Assistance" },
            { "value": "medical", "label": "Medical Care" },
            { "value": "mental_health", "label": "Counseling / Mental Health Support" },
            { "value": "legal", "label": "Legal Help" },
            { "value": "interpretation", "label": "Language Interpretation" },
            { "value": "transportation", "label": "Transportation" },
            { "value": "child_services", "label": "Child-Related Support" },
            { "value": "financial", "label": "Financial Assistance" }
          ],
          "tag_map": {
            "shelter": ["housing_shelter"],
            "food": ["food_assistance"],
            "medical": ["medical_care"],
            "mental_health": ["mental_health"],
            "legal": ["legal_help", "immigration_legal_screening"],
            "interpretation": ["language_interpretation"],
            "transportation": ["transportation"],
            "child_services": ["child_services"],
            "financial": ["financial_assistance"]
          }
        }
      ]
    }
  ],
  "thresholds": {
    "safety_risk": { "moderate": 2, "high": 4 },
    "trafficking_score": { "moderate": 3, "high": 6 },
    "dv_score": { "moderate": 2, "high": 4 },
    "sexual_violence_score": { "moderate": 1, "high": 3 },
    "immigration_need": { "moderate": 1, "high": 3 },
    "labor_exploitation_score": { "moderate": 2, "high": 4 }
  },
  "threshold_tags": [
    {
      "score": "safety_risk",
      "min": 4,
      "tags": ["crisis_support", "safety_planning", "housing_shelter"]
    },
    {
      "score": "trafficking_score",
      "min": 6,
      "tags": ["trafficking_support", "case_management", "immigration_legal_screening", "victim_support"]
    },
    {
      "score": "dv_score",
      "min": 2,
      "tags": ["domestic_violence_support", "safety_planning", "victim_support"]
    },
    {
      "score": "sexual_violence_score",
      "min": 3,
      "tags": ["sexual_assault_support", "crisis_support", "victim_support", "mental_health"]
    },
    {
      "score": "immigration_need",
      "min": 2,
      "tags": ["immigration_legal_screening"]
    },
    {
      "score": "labor_exploitation_score",
      "min": 2,
      "tags": ["employment_support", "legal_help"]
    }
  ]
}